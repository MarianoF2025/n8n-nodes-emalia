  "description": "n8n community node for Emalia — email marketing platform",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "emalia",
    "email-marketing",
    "automation"
  ],
  "license": "MIT",
  "homepage": "https://emaliamail.com",
  "author": {
    "name": "EME Automations",
    "email": "info@emaliamail.com",
    "url": "https://emaliamail.com"
  },
  "repository": {
    "type": "git",
